# BigNuten Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the real values.
# NEVER commit your .env file — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Wallet / Signing ─────────────────────────────────────────────────────────
# Private key of the deployer/owner wallet — used ONLY for contract deployment
# scripts (npx hardhat run scripts/deploy.js).
# Payroll settlement and other weekly operations are done through MetaMask in
# the BigNuten UI — no private key is stored in GitHub Secrets or CI.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# HD wallet mnemonic — 12-word seed phrase for streakbot-live.js.
# When set, Hardhat derives 5 accounts (owner + Alice + Bob + Carol + Dave)
# from this mnemonic instead of using PRIVATE_KEY.
# Generate a fresh mnemonic: https://iancoleman.io/bip39/  (use it for testing only!)
# Fund the FIRST derived address (index 0) with real ETH before running the script.
HD_MNEMONIC=replace_me_1 replace_me_2 replace_me_3 replace_me_4 replace_me_5 replace_me_6 replace_me_7 replace_me_8 replace_me_9 replace_me_10 replace_me_11 replace_me_12

# ── RPC Endpoints ────────────────────────────────────────────────────────────
# Optimism Mainnet (production — chain ID 10)
OPTIMISM_MAINNET_RPC_URL=https://mainnet.optimism.io

# Optimism Sepolia testnet (staging — chain ID 11155420)
OPTIMISM_RPC_URL=https://sepolia.optimism.io

# Polygon Mumbai testnet
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com

# Base Sepolia testnet
BASE_RPC_URL=https://sepolia.base.org

# ── Block Explorer API Keys (for contract verification) ──────────────────────
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ── Deployed Contract Addresses ──────────────────────────────────────────────
# Populate these after running `npx hardhat run scripts/deploy.js --network optimism`
BNUT_CONTRACT_ADDRESS=0x733c4d2Aae900E608147dd89Fa93606f89722823
TREASURY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
SUBSCRIPTION_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
GOVERNANCE_CONTRACT_ADDRESS=0x58c21942716eB78aCfeD1BACE81f5189bad5E2cD

# Aave V3 Pool on Optimism Mainnet — used by streakbot-live.js for yield scenarios.
# Leave blank (or 0x0000…) to skip yield and use ETH competitions only.
# Optimism mainnet Aave V3: 0x794a61358D6845594F94dc1DB02A252b5b4814aD
AAVE_POOL_ADDRESS=0x794a61358D6845594F94dc1DB02A252b5b4814aD

# ── Live Sim Config (streakbot-live.js) ───────────────────────────────────────
# How long each competition lasts (in hours).  Default: 24 (1 day).
# For a quick smoke-test you can set this to 2 (2 hours).
COMP_DURATION_HOURS=24

# Per-entrant ETH stake (in ETH, not wei).  Default: 0.0001 (~$0.0003 on Optimism).
STAKE_ETH=0.0001

# ETH/USD price used only for USD cost display in the estimate phase.
# Does not affect any on-chain amounts.  Update to current price for accurate estimates.
ETH_PRICE_USD=3000

# ── PayPal (Subscription Payments — Issue #40) ───────────────────────────────
# Obtain from https://developer.paypal.com/
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET

# ── Stripe (Credit/Debit Subscriptions — Issue #41) ──────────────────────────
# BigNuten uses Stripe Payment Links (serverless) — no server, no API keys
# needed in this file. Configure the checkout URLs directly in js/stripe-config.js.
# See docs/STRIPE_SETUP.md for the 3-step Payment Links setup guide.

# ── GitHub Actions (Bounty Bot — Issues #45, #46) ────────────────────────────
# GITHUB_TOKEN is automatically available in Actions workflows (no secret needed).
# PRIVATE_KEY is NOT required for the bounty-payout workflow — payouts are
# queued in payroll-queue.json and settled weekly via the BigNuten UI + MetaMask.
# CONTRIBUTOR_ADDRESS — contributor wallet address (per-workflow-run input)
# BNUT_AMOUNT         — bounty amount in whole BNUT (per-workflow-run input)
# ISSUE_REF           — e.g. "TheJollyLaMa/BigNuten_Vanilla#45"
